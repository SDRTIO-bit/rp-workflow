PORT=5180
DATA_DIR=./data
PLUGINS_DIR=./plugins

# Real RP provider. Use one provider for RP MVP validation.
RP_PROVIDER=deepseek
RP_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=

# Alternative provider; do not set both unless intentionally testing provider registration.
OPENCODE_API_KEY=
OPENCODE_MODEL=deepseek-v4-flash

RP_WORKFLOW_VERSION=unified-v1
RP_MOCK=0

# Restart-safe stores for RP MVP validation.
AGENT_SESSION_STORE=file
AGENT_SESSION_DIR=./artifacts/rp-mvp-v1/agent-sessions
WORKFLOW_MEMORY_STORE=file
WORKFLOW_MEMORY_DIR=./artifacts/rp-mvp-v1/workflow-memory

# Explicit real-cost test gate.
RUN_REAL_RP_MVP_V1=0
RP_MVP_PORT=5190

# P-15.3A-2: SillyTavern Card Import (Server)
CARDS_DIR=./data/cards
MAX_CARD_BYTES=5242880
MAX_CARD_JSON_DEPTH=64
MAX_CARD_WORLDBOOK_ENTRIES=2000
MAX_CARD_GREETINGS=100
