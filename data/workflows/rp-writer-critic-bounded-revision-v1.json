        "config": {
          "profileId": "rp-critic",
          "modelId": "mock-model"
        }
      },
      {
        "id": "gate2",
        "type": "rpCriticQualityGate",
        "position": { "x": 2200, "y": 280 },
        "config": {
          "minContinuity": 0.7,
          "minPlayerAgency": 0.8,
          "rejectOnErrorIssue": true
        }
      },
      {
        "id": "output",
        "type": "playerOutput",
        "position": { "x": 2500, "y": 200 },
        "config": {
          "displayLabel": "Final Draft"
        }
      },
      {
        "id": "inspDraft1",
