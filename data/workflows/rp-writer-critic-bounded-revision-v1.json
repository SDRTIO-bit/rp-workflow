{
  "kind": "agent-workflow-platform.workflow",
  "version": 1,
  "exportedAt": "2026-06-15T00:00:00.000Z",
  "workflow": {
    "id": "rp-writer-critic-bounded-revision-v1",
    "name": "RP Writer Critic Bounded Revision V1",
    "version": 1,
    "description": "P-10: bounded writer-critic revision loop. Writer 1 → Critic 1 → Gate 1 → conditional route. Accept branch: draft1 → output. Revise branch: Writer 2 (revision) → Critic 2 → Gate 2 → output. Max 2 attempts, 1 revision.",
    "nodes": [
      {
        "id": "input",
        "type": "playerInput",
        "position": { "x": 100, "y": 50 },
        "config": {
          "text": "我把钥匙放到吧台上，看着银铃"
        }
      },
      {
        "id": "preset",
        "type": "markdownSource",
        "position": { "x": 100, "y": 180 },
        "config": {
          "content": "## Style\n- 中文文学叙事\n- 第三人称\n- 不超过300字"
        }
      },
      {
        "id": "criticRubric",
        "type": "markdownSource",
        "position": { "x": 100, "y": 310 },
        "config": {
          "content": "## Review Rubric\n\n- Draft must not control the player character\n- Draft must not reveal information the POV character cannot know\n- Draft must follow the preset style"
        }
      },
      {
        "id": "writer1",
        "type": "specializedAgent",
        "position": { "x": 400, "y": 80 },
        "config": {
          "profileId": "rp-writer",
          "modelId": "mock-model",
          "temperature": 0.8
        }
      },
      {
        "id": "critic1",
        "type": "specializedAgent",
        "position": { "x": 700, "y": 80 },
        "config": {
          "profileId": "rp-critic",
          "modelId": "mock-model"
        }
      },
      {
        "id": "gate1",
        "type": "rpCriticQualityGate",
        "position": { "x": 1000, "y": 80 },
        "config": {
          "minContinuity": 0.7,
          "minPlayerAgency": 0.8,
          "rejectOnErrorIssue": true
        }
      },
      {
        "id": "route",
        "type": "conditionalRoute",
        "position": { "x": 1300, "y": 80 },
        "config": {
          "conditionField": "accepted"
        }
      },
      {
        "id": "selector",
        "type": "finalDraftSelector",
        "position": { "x": 2200, "y": 200 },
        "config": {}
      },
      {
        "id": "writer2",
        "type": "specializedAgent",
        "position": { "x": 1600, "y": 280 },
        "config": {
          "profileId": "rp-writer",
          "modelId": "mock-model",
          "temperature": 0.8
        }
      },
      {
        "id": "critic2",
        "type": "specializedAgent",
