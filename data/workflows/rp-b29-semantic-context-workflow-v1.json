  "workflow": {
    "id": "rp-b29-semantic-context-v1",
    "name": "RP B-2.9 Semantic Context Workflow",
    "version": 1,
    "description": "B-2.9: userInput -> worldbookRetriever -> parserInputBuilder -> llmParser -> semanticExpander -> contextAssemblerV2 -> promptCompiler -> writer -> textOutput. Worldbook data loaded via resource binding (worldbookSource).",
    "resources": {
      "worldbook:b29-test-world": {
